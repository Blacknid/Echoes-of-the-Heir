{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run Game (Gradle)",
            "type": "shell",
            "command": "./gradlew.bat desktop:run",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}

# ---------------------------------------------------------------------------
# Michi's Adventure — server secrets.
#
#   cp .env.example .env      then fill in the values below.
#
# .env is gitignored. NEVER commit the real file — every value here is a secret.
# docker-compose reads it automatically (`docker compose up -d --build`).
# ---------------------------------------------------------------------------

# Shared secret between save_server and multiplayer_server, so the MP server can ask
# "is this player's license real?" over the internal (non-internet-facing) license API.
# The two MUST match, or every multiplayer login fails.
#
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MICHI_INTERNAL_API_KEY=

# --- itch.io proof-of-purchase ---------------------------------------------------
# Your itch.io API key: https://itch.io/user/settings/api-keys  (press "Generate new key")
# This is YOUR developer key, not a player's. It never leaves the server and is never
# shipped to clients — it is what lets the server ask itch "did this user buy my game?".
#
# If this is left empty, the purchase gate is DISABLED and the server will hand a free
# license to anyone who asks for one. That is the old behaviour — set it before launch.
MICHI_ITCH_API_KEY=

# The NUMERIC id of the game on itch.io — not the URL slug.
# Find it at: https://itch.io/game/edit/<this-number>  (or the "id" field in the API).
MICHI_ITCH_GAME_ID=

# Numeric itch.io user id(s) that always pass the purchase gate, comma-separated.
# itch.io's download_keys API only returns *claimed purchase* keys — the game's own
# developer/admin never holds one for their own game, so without this you (the owner)
# would be locked out of your own gated build. Find your id at https://itch.io/api/1/key/me
# (or in the OAuth /me response). Optional — leave empty if not needed.
MICHI_ITCH_OWNER_USER_IDS=

# --- Admin dashboard --------------------------------------------------------------
# Password for the MP admin dashboard. docker-compose binds it to the VPS loopback only,
# so reach it through an SSH tunnel rather than exposing it:
#   ssh -L 8888:127.0.0.1:8888 root@142.93.103.51
#   then open http://127.0.0.1:8888/
# Leave empty to disable the dashboard entirely.
MICHI_ADMIN_PASSWORD=

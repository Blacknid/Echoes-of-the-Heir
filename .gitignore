/deploy

# Build artifacts
jpackage_tmp/
crash_log.txt
*.log
*.class

# Gradle (libGDX build)
.gradle/
**/build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/packaging.gradle
.idea/
*.iml
bin/
out/

# Server runtime files
SERVERS/save_server/saves.db
SERVERS/save_server/server.log
SERVERS/multiplayer_server/*.db

# Server secrets: internal API key, itch.io developer API key, admin password.
# Only .env.example (with empty values) belongs in the repo.
SERVERS/.env
!SERVERS/.env.example

# Server private keys — NEVER commit these. Anyone holding them can impersonate the save/MP
# servers, and the patch key can SIGN MALICIOUS GAME UPDATES. NOTE: copies are already tracked
# in git history; after rotating the keys, untrack them with:
#   git rm --cached SERVERS/*/server_private_key.pem SERVERS/patch_server/patch_private_key.pem
*.pem
SERVERS/save_server/saves/
SERVERS/save_server/server_private_key.pem
SERVERS/multiplayer_server/server_private_key.pem
SERVERS/patch_server/patch_private_key.pem

# Android release keystore + password — already tracked too; untrack after securing a backup:
#   git rm --cached build_tools/keystore/michis-adventure-release.jks*
build_tools/keystore/*.jks
build_tools/keystore/*.passwd.txt

# The client's local license credentials (activation_id + encrypted blob). Machine-specific;
# committing it would hand your license to everyone who clones the repo.
activation.dat

# Android SDK dropped directly into android/ (large, machine-specific — not shipped in the repo)
android/build-tools/
android/cmdline-tools/
android/licenses/
android/platform-tools/
android/platforms/
android/.knownPackages
android/.temp/
android/.cxx/
android/libs/
# AGP reads local.properties (sdk.dir) from the ROOT project directory, not the module dir.
local.properties

# Release signing key and credentials — never commit, losing these breaks Play Store updates.
android/release.keystore
android/keystore.properties
*.dat
owner_launch.bat

# Built by `./gradlew :core:engineJar` — the authoritative gameplay engine the MP server
# launches. A ~100 MB build artifact (bundles assets + natives), not source; regenerate it.
SERVERS/multiplayer_server/engine.jar

